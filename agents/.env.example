# Agent API keys — copy the relevant lines to ~/.zshrc or ~/.bashrc.
# NEVER commit real values; the placeholders below are safe to commit.
#
# This file is reference documentation only; it is not sourced automatically.

# ── Claude Code ───────────────────────────────────────────────────────────────
# Required if NOT authenticating via browser (the 'claude' interactive login
# flow works for Claude Max and Claude Pro subscribers without an API key).
# API keys:  https://console.anthropic.com → API Keys
#
# export ANTHROPIC_API_KEY="sk-ant-api03-YOUR_KEY_HERE"

# ── OpenAI Codex ──────────────────────────────────────────────────────────────
# Note: ChatGPT Plus / Pro subscriptions do NOT include API credits.
# You need a separate platform.openai.com billing account.
# API keys:  https://platform.openai.com/api-keys
#
# export OPENAI_API_KEY="sk-YOUR_KEY_HERE"
